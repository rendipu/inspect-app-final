# ─── Database (MongoDB Atlas) ─────────────────────────────────────────────────
# Format: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/inspect_db?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/inspect_db?retryWrites=true&w=majority"

# ─── JWT Secret ───────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="ganti-dengan-random-string-64-karakter"

# ─── Cloudinary ───────────────────────────────────────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME="your-cloud-name"
VITE_CLOUDINARY_UPLOAD_PRESET="inspect-unsigned"

# ─── API URL (kosongkan di Vercel, isi saat dev lokal jika beda port) ─────────
VITE_API_URL=""

# ─── CORS origins (kosong = semua diizinkan) ──────────────────────────────────
ALLOWED_ORIGINS=""
